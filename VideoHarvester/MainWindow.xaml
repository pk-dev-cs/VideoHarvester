<Window x:Class="VideoHarvester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:VideoHarvester.Converters"
        Title="VideoHarvester"
        Width="760" Height="620" MinWidth="620" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#0F1117" Foreground="#F7F8FA"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:StatusColorConverter x:Key="StatusColorConverter" />
            <converters:ButtonVisibilityConverter x:Key="ButtonVisibilityConverter" />
            <converters:DependencyStatusColorConverter x:Key="DependencyStatusColorConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:BytesToImageConverter x:Key="BytesToImageConverter" />
            <converters:FileSizeConverter x:Key="FileSizeConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with Hamburger Menu -->
        <Border Grid.Row="0" Background="#151922" BorderBrush="#252B38" BorderThickness="0,0,0,1">
            <Grid Margin="28,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="44" Height="44" CornerRadius="12" Background="#202735" ClipToBounds="True">
                    <Image Source="pack://application:,,,/VideoHarvester;component/Images/logo.png"
                           Width="44" Height="44" Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality">
                        <Image.Clip>
                            <RectangleGeometry Rect="0,0,44,44" RadiusX="12" RadiusY="12" />
                        </Image.Clip>
                    </Image>
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Video Harvester" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="Download video and audio from your preferred source"
                               Margin="0,3,0,0" Foreground="#98A2B3" FontSize="13" />
                </StackPanel>

                <!-- Hamburger Menu Button -->
                <Button Grid.Column="2" 
                        Width="44" Height="44" 
                        Style="{StaticResource IconButtonStyle}"
                        Click="HamburgerButton_Click"
                        ToolTip="Menu">
                    <TextBlock Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="20" />
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="28,24,28,28" Visibility="{Binding IsQueueView, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="22" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SurfaceCardStyle}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="SOURCE" Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="VIDEO URL" Style="{StaticResource FieldLabelStyle}" />

                    <ComboBox Grid.Row="2" Grid.Column="0" Height="42"
                              ItemsSource="{Binding AvailableSources}"
                              SelectedItem="{Binding SelectedSource}" />

                    <TextBox Grid.Row="2" Grid.Column="2" x:Name="VideoIdTextBox" Height="42"
                             VerticalContentAlignment="Center"
                             Text="{Binding VideoId, UpdateSourceTrigger=PropertyChanged}" />

                    <Button Grid.Row="2" Grid.Column="4" Height="42" MinWidth="108"
                            Content="Add to queue"
                            Command="{Binding AddToQueueCommand}"
                            CommandParameter="{Binding VideoId}"
                            Style="{StaticResource PrimaryButtonStyle}" />

                    <CheckBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                              IsChecked="{Binding UseOrderNumeration}"
                              VerticalAlignment="Center">
                        <CheckBox.Content>
                            <TextBlock Text="Order numeration" 
                                       Foreground="#9FB8D8" 
                                       FontSize="13" />
                        </CheckBox.Content>
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="18" Height="18" 
                                                        Background="#1D2635" 
                                                        BorderBrush="#475569" 
                                                        BorderThickness="1.5" 
                                                        CornerRadius="4"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="&#xE73E;" 
                                                               FontFamily="Segoe MDL2 Assets" 
                                                               FontSize="12"
                                                               Foreground="#60A5FA"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Visibility="{TemplateBinding IsChecked, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                </Border>
                                                <ContentPresenter VerticalAlignment="Center" />
                                            </StackPanel>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Download queue" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Border Grid.Column="1" Background="#1D2635" CornerRadius="10" Padding="10,5">
                    <TextBlock Text="{Binding DownloadQueue.Count, StringFormat={}{0} items}"
                               Foreground="#9FB8D8" FontSize="12" />
                </Border>
            </Grid>

            <Border Grid.Row="4" Style="{StaticResource QueuePanelStyle}">
                <ListBox x:Name="DownloadQueueListBox"
                         ItemsSource="{Binding DownloadQueue}"
                         Background="Transparent" BorderThickness="0"
                         Padding="10" HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource CustomListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource QueueItemCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Thumbnail -->
                                    <Border Grid.Row="0" Grid.RowSpan="6" Grid.Column="0"
                                            Width="120" Height="68" 
                                            Background="#1D2635" 
                                            CornerRadius="6"
                                            BorderBrush="#2D3848" 
                                            BorderThickness="1">
                                        <Grid>
                                            <!-- Thumbnail Image -->
                                            <Image Source="{Binding ThumbnailImage}" 
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ThumbnailImage}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>

                                            <!-- Placeholder when no thumbnail -->
                                            <TextBlock Text="&#xE714;" 
                                                       FontFamily="Segoe MDL2 Assets" 
                                                       FontSize="32"
                                                       Foreground="#475569"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ThumbnailImage}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <TextBlock Text="{Binding Source}" Foreground="#60A5FA"
                                                   FontSize="11" FontWeight="SemiBold" />

                                        <!-- Title (if available) -->
                                        <TextBlock Text="{Binding Title}" Margin="0,5,20,0"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#F7F8FA" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Title}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Title}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Title}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- VideoId (fallback if no Title) -->
                                        <TextBlock Text="{Binding VideoId}" Margin="0,5,20,0"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#F7F8FA" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding VideoId}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Title}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Title}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- Quality info -->
                                        <TextBlock Text="{Binding Quality}" Margin="0,3,0,0"
                                                   FontSize="11" Foreground="#7E899A"
                                                   TextTrimming="CharacterEllipsis">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Quality}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Quality}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <Button Grid.Row="0" Grid.Column="3" Grid.RowSpan="3"
                                            Width="38" Height="38" ToolTip="Open containing folder"
                                            Visibility="{Binding Status, Converter={StaticResource ButtonVisibilityConverter}}"
                                            Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding FilePath}"
                                            Style="{StaticResource IconButtonStyle}">
                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                    </Button>

                                    <ProgressBar Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Height="6" Maximum="100" Value="{Binding Progress}" />

                                    <Grid Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2">
                                        <TextBlock Text="{Binding Status}" FontSize="12"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}" />
                                        <TextBlock Text="{Binding Progress, StringFormat={}{0}%}" HorizontalAlignment="Right"
                                                   Foreground="#7E899A" FontSize="12" />
                                    </Grid>

                                    <!-- Error Message Display -->
                                    <Border Grid.Row="5" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,8,0,0"
                                            Background="#2D1B1E" BorderBrush="#7F1D1D" BorderThickness="1"
                                            CornerRadius="4" Padding="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="4" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="⚠ Error Details" 
                                                       FontSize="11" FontWeight="SemiBold" 
                                                       Foreground="#FCA5A5" />
                                            <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}"
                                                       FontSize="11" FontFamily="Consolas"
                                                       Foreground="#FEF2F2" TextWrapping="Wrap"
                                                       MaxHeight="200" TextTrimming="CharacterEllipsis">
                                                <TextBlock.ToolTip>
                                                    <ToolTip MaxWidth="600">
                                                        <TextBlock Text="{Binding ErrorMessage}" 
                                                                   TextWrapping="Wrap" 
                                                                   FontFamily="Consolas" 
                                                                   FontSize="11" />
                                                    </ToolTip>
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <!-- History View -->
        <Grid Grid.Row="1" Margin="28,24,28,28" Visibility="{Binding IsQueueView, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="22" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Download History" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" 
                        Height="36" MinWidth="100"
                        Content="Refresh"
                        Command="{Binding RefreshHistoryCommand}"
                        Style="{StaticResource PrimaryButtonStyle}">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" />
                                <TextBlock Text="Refresh" FontSize="13" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource QueuePanelStyle}">
                <ListBox ItemsSource="{Binding DownloadHistory}"
                         Background="Transparent" BorderThickness="0"
                         Padding="10" HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource CustomListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource QueueItemCardStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Thumbnail -->
                                    <Border Grid.Row="0" Grid.RowSpan="5" Grid.Column="0"
                                            Width="120" Height="68" 
                                            Background="#1D2635" 
                                            CornerRadius="6"
                                            BorderBrush="#2D3848" 
                                            BorderThickness="1">
                                        <Grid>
                                            <!-- Thumbnail Image from binary data -->
                                            <Image Source="{Binding ThumbnailData, Converter={StaticResource BytesToImageConverter}}" 
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ThumbnailData}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>

                                            <!-- Placeholder when no thumbnail -->
                                            <TextBlock Text="&#xE714;" 
                                                       FontFamily="Segoe MDL2 Assets" 
                                                       FontSize="32"
                                                       Foreground="#475569"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ThumbnailData}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>

                                    <!-- Header Row -->
                                    <StackPanel Grid.Row="0" Grid.Column="2">
                                        <!-- Title (if available) -->
                                        <TextBlock Text="{Binding Title}" 
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#F7F8FA" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding Title}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Title}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Title}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- SourceUrl (always shown as subtitle or main title) -->
                                        <TextBlock Text="{Binding SourceUrl}" Margin="0,4,0,0"
                                                   FontSize="11" Foreground="#7E899A" 
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding SourceUrl}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <!-- When Title exists, show as small subtitle -->
                                                    <Setter Property="FontSize" Value="11" />
                                                    <Setter Property="Foreground" Value="#7E899A" />
                                                    <Setter Property="FontWeight" Value="Normal" />
                                                    <Style.Triggers>
                                                        <!-- When no Title, show as main heading -->
                                                        <DataTrigger Binding="{Binding Title}" Value="{x:Null}">
                                                            <Setter Property="FontSize" Value="14" />
                                                            <Setter Property="Foreground" Value="#F7F8FA" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                            <Setter Property="Margin" Value="0,0,0,0" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Title}" Value="">
                                                            <Setter Property="FontSize" Value="14" />
                                                            <Setter Property="Foreground" Value="#F7F8FA" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                            <Setter Property="Margin" Value="0,0,0,0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Status Badge -->
                                    <Border Grid.Row="0" Grid.Column="3"
                                            Background="#1D2635" 
                                            CornerRadius="4" 
                                            Padding="8,4"
                                            VerticalAlignment="Top"
                                            Margin="12,0,0,0">
                                        <TextBlock Text="{Binding Status}" 
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}" />
                                    </Border>

                                    <!-- Open Folder Button -->
                                    <Button Grid.Row="0" Grid.Column="3" Grid.RowSpan="3"
                                            Width="38" Height="38" 
                                            ToolTip="Open containing folder"
                                            Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding LocalPath}"
                                            Margin="12,40,0,0"
                                            VerticalAlignment="Top">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LocalPath}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding LocalPath}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                                    </Button>

                                    <!-- Metadata Row -->
                                    <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Format, StringFormat='Format: {0}'}" 
                                                   FontSize="11" Foreground="#7E899A" Margin="0,0,16,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Format}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Format}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Quality, StringFormat='Quality: {0}'}" 
                                                   FontSize="11" Foreground="#7E899A" Margin="0,0,16,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Quality}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Quality}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding FileSize, Converter={StaticResource FileSizeConverter}}" Margin="0,0,16,0"
                                                   FontSize="11" Foreground="#7E899A">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FileSize}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding CreatedAt, StringFormat='Started: {0:g}'}" 
                                                   FontSize="11" Foreground="#7E899A" />
                                    </StackPanel>

                                    <!-- Error Message -->
                                    <Border Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" Margin="0,8,0,0"
                                            Background="#2D1B1E" BorderBrush="#7F1D1D" BorderThickness="1"
                                            CornerRadius="4" Padding="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="4" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="⚠ Error Details" 
                                                       FontSize="11" FontWeight="SemiBold" 
                                                       Foreground="#FCA5A5" />
                                            <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}"
                                                       FontSize="11" FontFamily="Consolas"
                                                       Foreground="#FEF2F2" TextWrapping="Wrap"
                                                       MaxHeight="100" TextTrimming="CharacterEllipsis">
                                                <TextBlock.ToolTip>
                                                    <ToolTip MaxWidth="600">
                                                        <TextBlock Text="{Binding ErrorMessage}" 
                                                                   TextWrapping="Wrap" 
                                                                   FontFamily="Consolas" 
                                                                   FontSize="11" />
                                                    </ToolTip>
                                                </TextBlock.ToolTip>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <!-- Footer with Dependency Status -->
        <Border Grid.Row="2" Background="#151922" BorderBrush="#252B38" BorderThickness="0,1,0,0" Padding="28,12">
            <ItemsControl ItemsSource="{Binding Dependencies}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="16,0">
                            <TextBlock Text="{Binding Icon}" 
                                       FontFamily="Segoe MDL2 Assets" 
                                       FontSize="16"
                                       Foreground="{Binding IsAvailable, Converter={StaticResource DependencyStatusColorConverter}}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Name}" 
                                       FontSize="12" 
                                       Margin="6,0,0,0"
                                       Foreground="{Binding IsAvailable, Converter={StaticResource DependencyStatusColorConverter}}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- Sliding Menu Panel -->
        <Border x:Name="MenuPanel" 
                Grid.Row="0" Grid.RowSpan="3"
                Width="320" 
                HorizontalAlignment="Right"
                Background="#151922" 
                BorderBrush="#252B38" 
                BorderThickness="1,0,0,0"
                Panel.ZIndex="100">
            <Border.RenderTransform>
                <TranslateTransform X="320" />
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Menu Header -->
                <Border Grid.Row="0" Background="#1D2635" BorderBrush="#252B38" BorderThickness="0,0,0,1" Padding="20,16">
                    <Grid>
                        <TextBlock Text="Menu" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button HorizontalAlignment="Right" 
                                Width="32" Height="32"
                                Style="{StaticResource IconButtonStyle}"
                                Click="CloseMenuButton_Click"
                                ToolTip="Close">
                            <TextBlock Text="&#xE10A;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                        </Button>
                    </Grid>
                </Border>

                <!-- Menu Items -->
                <StackPanel Grid.Row="1" Margin="0,12,0,0">
                    <Button x:Name="QueueListButton" 
                            Height="52" 
                            Padding="20,0"
                            HorizontalContentAlignment="Left"
                            Style="{StaticResource MenuItemButtonStyle}"
                            Click="QueueListButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="20" VerticalAlignment="Center" />
                            <TextBlock Text="Queue List" FontSize="15" Margin="16,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="HistoryButton" 
                            Height="52" 
                            Padding="20,0"
                            HorizontalContentAlignment="Left"
                            Style="{StaticResource MenuItemButtonStyle}"
                            Click="HistoryButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="20" VerticalAlignment="Center" />
                            <TextBlock Text="Download History" FontSize="15" Margin="16,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Overlay for closing menu -->
        <Border x:Name="MenuOverlay" 
                Grid.Row="0" Grid.RowSpan="3"
                Background="#80000000" 
                Opacity="0"
                IsHitTestVisible="False"
                Panel.ZIndex="99"
                MouseDown="MenuOverlay_MouseDown" />
    </Grid>
</Window>
