<Window x:Class="VideoHarvester.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VideoHarvester" 
        Height="400" Width="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Border CornerRadius="10" Background="#0F1117" BorderBrush="#252B38" BorderThickness="2">
        <Grid>
            <!-- Splash Image - fills entire space -->
            <Image Source="Images/splash.png" 
                   Stretch="UniformToFill" />

            <!-- Loading Indicator - overlay at bottom -->
            <StackPanel VerticalAlignment="Bottom" 
                       HorizontalAlignment="Center" 
                       Margin="20"
                       Background="#CC0F1117">
                <TextBlock Text="Loading VideoHarvester..." 
                          FontSize="14"
                          Foreground="#F7F8FA"
                          HorizontalAlignment="Center"
                          Margin="10,10,10,5"/>
                <ProgressBar IsIndeterminate="True" 
                            Width="200" 
                            Height="4"
                            Background="#252B38"
                            Foreground="#4A9EFF"
                            Margin="10,5,10,10" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

